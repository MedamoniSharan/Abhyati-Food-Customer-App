NODE_ENV=development
PORT=4000

# Comma-separated frontend origins allowed for CORS (local + production)
ALLOWED_ORIGINS=http://localhost:5173,https://abhyati-food-customer-app.onrender.com

# Zoho OAuth app credentials
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_long_lived_refresh_token

# Optional: static access token for debugging only (normally use refresh token above)
# ZOHO_ACCESS_TOKEN=

# Zoho region:
# in, com, eu, com.au, jp, com.cn
ZOHO_REGION=in

# Optional fallback organization id.
# If omitted, backend auto-uses the first org from /organizations endpoint.
ZOHO_ORGANIZATION_ID=

# Invoice defaults
ZOHO_DEFAULT_CURRENCY_CODE=INR
ZOHO_DEFAULT_PAYMENT_TERMS=Due on Receipt

# Default test customer for login
AUTH_DEFAULT_CUSTOMER_EMAIL=customer@abhyati.com
AUTH_DEFAULT_CUSTOMER_PASSWORD=Abhyati@123

# Admin dashboard (override defaults in production)
ADMIN_EMAIL=admin@abhyati.com
ADMIN_PASSWORD=admin
JWT_SECRET=dev-jwt-secret-change-in-prod-32

# Zoho contact type for new drivers: vendor | customer
DRIVER_ZOHO_CONTACT_TYPE=vendor

# Chart of accounts id from Zoho Books — when set, each customer checkout creates quantity adjustments (stock down)
# ZOHO_INVENTORY_ADJUSTMENT_ACCOUNT_ID=
