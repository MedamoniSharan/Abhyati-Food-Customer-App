NODE_ENV=development
PORT=4000

# Comma-separated frontend origins allowed for CORS
ALLOWED_ORIGINS=http://localhost:5173

# Zoho OAuth app credentials
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_long_lived_refresh_token

# Zoho region:
# in, com, eu, com.au, jp, com.cn
ZOHO_REGION=in

# Optional fallback organization id.
# If omitted, backend auto-uses the first org from /organizations endpoint.
ZOHO_ORGANIZATION_ID=

# Invoice defaults
ZOHO_DEFAULT_CURRENCY_CODE=INR
ZOHO_DEFAULT_PAYMENT_TERMS=Due on Receipt
