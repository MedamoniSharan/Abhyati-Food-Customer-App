# Call a remote backend (e.g. Render) from the admin UI — use this when the API is not on localhost.
# No trailing slash.
VITE_API_BASE_URL=https://abhyati-food-customer-app.onrender.com

# When VITE_API_BASE_URL is empty, Vite proxies /api to this local backend (port should match backend PORT).
# VITE_PROXY_TARGET=http://localhost:3001
