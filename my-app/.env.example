# Optional: override API base (defaults to https://abhyati-food-customer-app.onrender.com in src/config/apiBase.ts)
# Browser dev with local backend:
# VITE_API_BASE_URL=http://localhost:4000
# Capacitor APK builds ignore localhost fallbacks; use HTTPS production URL unless you set a tunnel URL here.

# Google Maps Embed API (optional). Enable "Maps Embed API" for this key in Google Cloud Console.
# Without it, driver screens still show an "Open in Google Maps" link (uses device location when allowed).
# VITE_GOOGLE_MAPS_API_KEY=
