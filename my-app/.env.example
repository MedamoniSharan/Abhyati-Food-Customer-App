# API base (defaults to https://abhyati-food-customer-app.onrender.com in src/config/apiBase.ts)
VITE_API_BASE_URL=https://abhyati-food-customer-app.onrender.com

# Google Maps Embed API (optional). Enable "Maps Embed API" for this key in Google Cloud Console.
# Without it, driver screens still show an "Open in Google Maps" link (uses device location when allowed).
# VITE_GOOGLE_MAPS_API_KEY=
